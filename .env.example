# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Frontend Client Variables (Safe to expose)
# ============================================

# Supabase Configuration
VITE_SUPABASE_URL="https://ngduavjaiqyiqjzelfpl.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# Analytics / Observability
VITE_GA_ID="YOUR_GOOGLE_ANALYTICS_ID_HERE"
VITE_MIXPANEL_TOKEN="YOUR_MIXPANEL_TOKEN_HERE"
VITE_SENTRY_DSN="YOUR_SENTRY_DSN_HERE"
VITE_VERBOSE_LOGS="false"

# Push Notifications
VITE_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY_HERE"

# Razorpay Key ID (Only public key - safe for client)
VITE_RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY_ID_HERE"

# Razorpay plan mappings used by the pricing UI
# Razorpay plan IDs should be stored on each plan row in the
# `subscription_plans.razorpay_plan_id` column. Manage plan-to-Razorpay
# mappings via the admin Plans UI rather than environment variables.
# Example (do NOT hardcode in production):
# VITE_RAZORPAY_PLAN_MONTHLY="plan_monthly_99"

# ============================================
# Backend Variables (Supabase Secrets Only)
# These should NOT be in .env files
# Set them via Supabase Dashboard → Settings → Secrets
# ============================================

# Note: The following are stored in Supabase Secrets, NOT in code/env:
# 
# SUPABASE_URL = "https://ngduavjaiqyiqjzelfpl.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY = "YOUR_SERVICE_ROLE_KEY_HERE"
# GEMINI_API_KEY = "YOUR_GEMINI_API_KEY_HERE"
# OPENAI_API_KEY = "YOUR_OPENAI_API_KEY_HERE"
# RAZORPAY_KEY_ID = "YOUR_RAZORPAY_KEY_ID_HERE"
# RAZORPAY_KEY_SECRET = "YOUR_RAZORPAY_KEY_SECRET_HERE"

# ============================================
# Instructions for Backend Secrets Setup
# ============================================

# TO SET BACKEND SECRETS IN SUPABASE:
#
# Option 1: Via Dashboard
# 1. Go to Supabase Project Settings
# 2. Click "Secrets" tab
# 3. Click "New secret" for each key
# 4. Enter name and value
#
# Option 2: Via CLI
# supabase secrets set GEMINI_API_KEY "your_key"
# supabase secrets set OPENAI_API_KEY "your_key"
# supabase secrets set RAZORPAY_KEY_ID "your_key"
# supabase secrets set RAZORPAY_KEY_SECRET "your_key"
#
# Option 3: Via Supabase Web UI
# 1. Project Settings → Secrets → Add New
# 2. Paste each secret

# ============================================
# How to Get Each Key
# ============================================

# 1. SUPABASE_ANON_KEY
#    - Supabase Dashboard → Settings → API → anon (public)

# 2. SUPABASE_SERVICE_ROLE_KEY
#    - Supabase Dashboard → Settings → API → service_role (secret)
#    - ⚠️ NEVER commit to version control!

# 3. GEMINI_API_KEY
#    - Go to https://makersuite.google.com/app/apikey
#    - Click "Create API Key"
#    - Copy the key

# 4. OPENAI_API_KEY
#    - Go to https://platform.openai.com/api-keys
#    - Click "Create new secret key"
#    - Copy the key

# 5. RAZORPAY_KEY_ID & RAZORPAY_KEY_SECRET
#    - Razorpay Dashboard → Settings → API Keys
#    - Copy both Key ID and Key Secret

# ============================================
# Development Notes
# ============================================

# - .env.local is gitignored (safe to use locally)
# - Production values go into Supabase Secrets
# - Never commit real keys to git
# - Rotate keys regularly
# - Check API quotas before deployment
